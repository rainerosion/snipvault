{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnipVault",
  "version": "2.0.5",
  "identifier": "cn.rainss.snipvault",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SnipVault",
        "width": 1200,
        "height": 800,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "(https?://.+)|(mailto:.+)|(tel:.+)|(file://.+)|([a-zA-Z]:[\\\\/].+)|(\\\\\\\\.+)"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "rainerosion",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "wix": {
        "language": [
          "zh-CN",
          "en-US"
        ]
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}